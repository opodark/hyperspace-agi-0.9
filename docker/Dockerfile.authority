# Authority container - policy engine + model catalog for v5.9
# Pydantic-based policy engine, model routing, placement decisions

FROM python:3.12-slim

WORKDIR /authority

RUN pip install --no-cache-dir \
    pydantic==2.9.2 \
    httpx==0.27.2 \
    python-dotenv==1.0.1 \
    uvloop==0.20.0

COPY authority/ /authority/authority/
COPY shared/ /authority/shared/
COPY pyproject.toml /authority/

RUN pip install --no-cache-dir -e .

EXPOSE 8766

ENV AUTHORITY_API_PORT=8766 \
    OLLAMA_BASE_URL=http://ollama:11434 \
    POLICY_ENGINE_VERSION=1 \
    MODEL_CATALOG_ENABLED=true \
    ROUTING_STRATEGY=smart-4level

HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
    CMD curl -f http://localhost:8766/health || exit 1

CMD ["python", "-m", "authority.server"]
