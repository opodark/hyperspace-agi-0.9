# Authority container - Policy Engine v1 + Model Catalog API
# Fix: usa requirements.txt invece di pyproject.toml

FROM python:3.12-slim

WORKDIR /authority

RUN apt-get update && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt /authority/requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY authority/ /authority/authority/
COPY shared/    /authority/shared/

ENV PYTHONPATH=/authority

EXPOSE 8766

ENV AUTHORITY_API_PORT=8766 \
    OLLAMA_BASE_URL=http://ollama:11434

HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
    CMD curl -f http://localhost:8766/health || exit 1

CMD ["python", "-m", "authority.server"]
