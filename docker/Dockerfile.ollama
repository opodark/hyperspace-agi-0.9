# Ollama container - local model engine for v5.9
# Supports Qwen 3.5 7B/9B, Qwen Coder 9B/14B, Gemma 4, DeepSeek
# Target: Apple Silicon M5 (14B max)

FROM ollama/ollama:latest

WORKDIR /ollama

RUN mkdir -p /root/.ollama/models

EXPOSE 11434

HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:11434/api/tags || exit 1

CMD ["ollama", "serve"]
