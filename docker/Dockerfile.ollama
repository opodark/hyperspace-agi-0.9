# Ollama container - local model engine for v5.9
# NOTA: ollama/ollama ha gia ENTRYPOINT ["ollama"] CMD ["serve"] - non sovrascrivere
# Healthcheck: usa il binario 'ollama' sempre presente nell'immagine

FROM ollama/ollama:latest

RUN mkdir -p /root/.ollama/models

EXPOSE 11434

# 'ollama list' chiama le API REST interne - funziona senza curl/wget
HEALTHCHECK --interval=20s --timeout=15s --start-period=30s --retries=5 \
    CMD ollama list || exit 1
