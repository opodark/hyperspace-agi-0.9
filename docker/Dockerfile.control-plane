# Control Plane container - Smart Router 4-level + PullExecutor + API v5.9
# FIX: la directory 'control-plane' ha un trattino -> non importabile da Python
# Soluzione: COPY control-plane/ -> /control-plane/control_plane/ (underscore)

FROM python:3.12-slim

WORKDIR /control-plane

RUN apt-get update && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt /control-plane/requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# CRITICO: copia con nome underscore per 'import control_plane'
COPY control-plane/ /control-plane/control_plane/
COPY shared/        /control-plane/shared/
COPY authority/     /control-plane/authority/
COPY worker/        /control-plane/worker/
COPY node/          /control-plane/node/

ENV PYTHONPATH=/control-plane

EXPOSE 8768

ENV CONTROL_PLANE_API_PORT=8768 \
    OLLAMA_BASE_URL=http://ollama:11434 \
    SMART_ROUTING_ENABLED=true \
    ROUTING_LEVELS=4

HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
    CMD curl -f http://localhost:8768/health || exit 1

CMD ["python", "-m", "control_plane.server"]
