# Control Plane container - runtime + API routes for v5.9
# Smart routing 4-levels, model catalog API, votes API, replay API

FROM python:3.12-slim

WORKDIR /control-plane

RUN pip install --no-cache-dir \
    pydantic==2.9.2 \
    httpx==0.27.2 \
    aiosqlite==0.20.0 \
    python-dotenv==1.0.1 \
    uvloop==0.20.0 \
    fastapi==0.115.0 \
    starlette==0.40.0

COPY control-plane/ /control-plane/control-plane/
COPY shared/ /control-plane/shared/
COPY authority/ /control-plane/authority/
COPY worker/ /control-plane/worker/
COPY pyproject.toml /control-plane/

RUN pip install --no-cache-dir -e .

EXPOSE 8768

ENV CONTROL_PLANE_API_PORT=8768 \
    OLLAMA_BASE_URL=http://ollama:11434 \
    SMART_ROUTING_ENABLED=true \
    ROUTING_LEVELS=4 \
    MODEL_CATALOG_API_ENABLED=true \
    VOTES_API_ENABLED=true \
    REPLAY_API_ENABLED=true

HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
    CMD curl -f http://localhost:8768/health || exit 1

CMD ["python", "-m", "control_plane.server"]
