# Worker container - Dream Validator v2 + Vote Store + Replay Engine
# Fix: usa requirements.txt invece di pyproject.toml

FROM python:3.12-slim

WORKDIR /worker

RUN apt-get update && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt /worker/requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY worker/ /worker/worker/
COPY shared/ /worker/shared/

ENV PYTHONPATH=/worker

EXPOSE 8767

ENV WORKER_API_PORT=8767 \
    OLLAMA_BASE_URL=http://ollama:11434

HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
    CMD curl -f http://localhost:8767/health || exit 1

CMD ["python", "-m", "worker.server"]
