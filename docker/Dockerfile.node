# Node container - agent orchestrator for v5.9
# Manages Qwen 3.5 agents, Qwen Coder workers, reasoning traces

FROM python:3.12-slim

WORKDIR /node

RUN pip install --no-cache-dir \
    pydantic==2.9.2 \
    httpx==0.27.2 \
    aiosqlite==0.20.0 \
    asyncpg==0.30.0 \
    python-dotenv==1.0.1 \
    uvloop==0.20.0

COPY hyperspace_node/ /node/hyperspace_node/
COPY node/ /node/node/
COPY shared/ /node/shared/
COPY pyproject.toml /node/

RUN pip install --no-cache-dir -e .

EXPOSE 8765

ENV NODE_API_PORT=8765 \
    OLLAMA_BASE_URL=http://ollama:11434 \
    NODE_ID=default-node \
    NODE_ROLE=orchestrator \
    DEFAULT_AGENT_MODEL=qwen3.5:7b \
    DEFAULT_CODER_MODEL=qwen-coder:14b \
    DEFAULT_REASONER_MODEL=deepseek-r1:14b

HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
    CMD curl -f http://localhost:8765/health || exit 1

CMD ["python", "-m", "node.orchestrator"]
