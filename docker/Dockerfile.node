# Node container - Agent Runtime + Tiered Memory Store v5.9
# Fix: usa requirements.txt invece di pyproject.toml

FROM python:3.12-slim

WORKDIR /node

RUN apt-get update && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt /node/requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY node/   /node/node/
COPY shared/ /node/shared/

ENV PYTHONPATH=/node

EXPOSE 8765

ENV NODE_API_PORT=8765 \
    OLLAMA_BASE_URL=http://ollama:11434 \
    MEMORY_STATE_DIR=/node/shared/memory

VOLUME ["/node/shared/memory"]

HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
    CMD curl -f http://localhost:8765/health || exit 1

CMD ["python", "-m", "node.server"]
